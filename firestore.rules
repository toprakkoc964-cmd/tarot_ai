rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function doesNotCreateProtectedFields() {
      return !request.resource.data.keys().hasAny([
        'wallet',
        'entitlements',
        'coffeeAnalysis'
      ]);
    }

    function doesNotChangeProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'wallet',
        'entitlements',
        'coffeeAnalysis'
      ]);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && doesNotCreateProtectedFields();
      allow update: if isOwner(uid) && doesNotChangeProtectedFields();
      allow delete: if isOwner(uid);

      match /readings/{readingId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid);
        allow delete: if false;
      }

      match /credit_ledger/{txId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /idempotency/{key} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /coffee_readings/{readingId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /coffee_reservations/{reservationId} {
        allow read, write: if false;
      }

      match /iap_transactions/{txId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /fcm_tokens/{token} {
        allow read: if isOwner(uid);
        allow create, update, delete: if isOwner(uid);
      }

      match /aris_sessions/{sessionId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /guests/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && !request.resource.data.keys().hasAny([
          'wallet',
          'entitlements',
          'credits'
        ]);
      allow delete: if isOwner(uid);
    }

    match /apple_auth/{document=**} {
      allow read, write: if false;
    }

    match /diagnostics/{uid}/camera/{logId} {
      allow read, create: if isOwner(uid);
      allow update, delete: if false;
    }

    match /app_localization/{lang} {
      allow read: if true;
      allow write: if false;
    }

    match /ai_personas/{personaId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
