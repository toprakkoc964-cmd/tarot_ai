rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function walletUnchanged() {
      return !('wallet' in request.resource.data) ||
        (resource != null &&
         'wallet' in resource.data &&
         request.resource.data.wallet.credits == resource.data.wallet.credits);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && walletUnchanged();
      allow delete: if false;

      match /readings/{readingId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid);
        allow delete: if false;
      }

      match /credit_ledger/{txId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /idempotency/{key} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /iap_transactions/{txId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /fcm_tokens/{token} {
        allow read: if isOwner(uid);
        allow create, update, delete: if isOwner(uid);
      }
    }

    match /app_localization/{lang} {
      allow read: if true;
      allow write: if false;
    }

    match /ai_personas/{personaId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
